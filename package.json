{
  "name": "splynx-api",
  "private": true,
  "workspaces": ["apps/*", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=apps/dashboard\"",
    "build": "npm run build --workspace=server && npm run build --workspace=apps/dashboard"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
